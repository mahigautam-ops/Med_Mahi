<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="52dp"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="4dp">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_shield"
                android:contentDescription="Secure" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="CLINICAL SECURE LINE"
                android:textColor="#4CAF50"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.15" />
        </LinearLayout>

        <TextView
            android:id="@+id/incomingLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="28dp"
            android:text="INCOMING CLINICAL CALL"
            android:textColor="#1A1A1A"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <!-- Avatar -->
        <ImageView
            android:id="@+id/avatar"
            android:layout_width="76dp"
            android:layout_height="76dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/circle_avatar_bg"
            android:src="@drawable/ic_person"
            android:scaleType="centerCrop"
            android:layout_marginBottom="12dp"
            android:contentDescription="Caller" />

        <!-- Name -->
        <TextView
            android:id="@+id/callerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Unknown Caller"
            android:textColor="#1A1A1A"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp" />

        <!-- Number -->
        <TextView
            android:id="@+id/callerNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text=""
            android:textColor="#999999"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Clinical Context Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/clinical_card_bg"
            android:paddingHorizontal="18dp"
            android:paddingVertical="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CLINICAL CONTEXT"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="14dp" />

            <!-- Chief Complaint -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chief Complaint"
                android:textColor="#BBBBBB"
                android:textSize="11sp"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/chiefComplaint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="12dp" />

            <!-- Prescribed Medication -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Prescribed Medication"
                android:textColor="#BBBBBB"
                android:textSize="11sp"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/medication"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="12dp" />

            <!-- Previous Issues -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Previous Issues"
                android:textColor="#BBBBBB"
                android:textSize="11sp"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/previousIssues"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="#1A1A1A"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="12dp" />

            <!-- Status -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status"
                android:textColor="#BBBBBB"
                android:textSize="11sp"
                android:layout_marginBottom="4dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/statusDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/status_dot_bg"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#1A1A1A"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:id="@+id/addPatientBtn"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:background="@drawable/btn_add_patient_bg"
                android:gravity="center"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+ Add New Patient"
                    android:textColor="#2962FF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/videoCallBtn"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:background="@drawable/btn_video_call_bg"
                android:gravity="center"
                android:orientation="horizontal"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Video Call"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Control Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="28dp">

            <!-- Mute -->
            <LinearLayout
                android:id="@+id/muteBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/muteIcon"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/control_btn_bg"
                    android:src="@drawable/ic_mute"
                    android:scaleType="center"
                    android:padding="14dp"
                    android:contentDescription="Mute" />

                <TextView
                    android:id="@+id/muteLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Mute"
                    android:textColor="#888888"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Keypad -->
            <LinearLayout
                android:id="@+id/keypadBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/keypadIcon"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/control_btn_bg"
                    android:src="@drawable/ic_keypad"
                    android:scaleType="center"
                    android:padding="14dp"
                    android:contentDescription="Keypad" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Keypad"
                    android:textColor="#888888"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Speaker -->
            <LinearLayout
                android:id="@+id/speakerBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/speakerIcon"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/control_btn_bg"
                    android:src="@drawable/ic_speaker"
                    android:scaleType="center"
                    android:padding="14dp"
                    android:contentDescription="Speaker" />

                <TextView
                    android:id="@+id/speakerLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Speaker"
                    android:textColor="#888888"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Record -->
            <LinearLayout
                android:id="@+id/recordBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/recordIcon"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/control_btn_bg"
                    android:src="@drawable/ic_record"
                    android:scaleType="center"
                    android:padding="14dp"
                    android:contentDescription="Record" />

                <TextView
                    android:id="@+id/recordLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Record"
                    android:textColor="#888888"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Answer / Decline -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/rejectBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/circle_reject_bg"
                    android:src="@drawable/ic_call_end"
                    android:scaleType="center"
                    android:padding="16dp"
                    android:contentDescription="Decline" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Decline"
                    android:textColor="#E53935"
                    android:textSize="13sp" />
            </LinearLayout>

            <View
                android:layout_width="48dp"
                android:layout_height="1dp"
                android:visibility="invisible" />

            <LinearLayout
                android:id="@+id/answerBtn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/circle_answer_bg"
                    android:src="@drawable/ic_call"
                    android:scaleType="center"
                    android:padding="16dp"
                    android:contentDescription="Answer" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Answer"
                    android:textColor="#4CAF50"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
